# --- Ollama Configuration ---
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:0.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- ChromaDB ---
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=personal_profile

# --- Retrieval ---
DEFAULT_N_RESULTS=3

# --- Chunking ---
# Strategy: paragraph | recursive | semantic
DEFAULT_CHUNK_STRATEGY=paragraph
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50

# --- Rate Limiting ---
RATE_LIMIT_RAG=60/minute
RATE_LIMIT_DOCS=200/minute

# --- Authentication ---
# Set to true and provide an API_KEY to require X-API-Key header on requests
API_KEY_ENABLED=false
API_KEY=

# --- API ---
APP_TITLE=RAG API
APP_VERSION=2.0.0
# Comma-separated origins, e.g. http://localhost:3000,https://myapp.com
CORS_ORIGINS=["*"]

# --- Logging ---
LOG_LEVEL=INFO
